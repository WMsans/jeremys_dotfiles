// Niri config - modular structure
// See individual files for detailed settings

include "input.kdl"
include "output.kdl"
include "layout.kdl"
include "animations.kdl"
include "window-rules.kdl"
include "binds.kdl"

// Top-level settings
prefer-no-csd
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// Startup applications
spawn-at-startup "waybar"
spawn-at-startup "mako"
spawn-at-startup "fcitx5"
spawn-at-startup "dbus-update-activation-environment" "--systemd" "WAYLAND_DISPLAY" "XDG_CURRENT_DESKTOP=GNOME"

hotkey-overlay {
    // skip-at-startup
}
